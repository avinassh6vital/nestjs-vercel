// {
//   "version": 2,
//   "rewrites": [
//     {
//       "source": "/(.*)",
//       "destination": "/api"
//     }
//   ]
// }


{
  "version": 2,
  "builds": [
    {
      "src": "src/main.ts",
      "use": "@vercel/node"
    }
  ],
  "routes": [
    {
      "src": "/(.*)",
      "dest": "src/main.ts",
      "methods": ["GET", "POST", "PUT", "DELETE", "PATCH", "OPTIONS"]
    }
  ]
}
